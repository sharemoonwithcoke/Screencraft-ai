# ── Dev flags ─────────────────────────────────────────────────────────────────
# Set to "true" to skip auth checks locally (login page still works normally).
# NEVER set this in production.
DEV_BYPASS_AUTH=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/screencraft

# ── Storage (Google Cloud Storage) ────────────────────────────────────────────
GCS_PROJECT_ID=your_gcp_project_id
GCS_BUCKET=screencraft-videos
# Path to service account JSON key file.
# Leave empty to use Application Default Credentials (ADC)
# — recommended when running on Cloud Run / GCE / GKE.
GCS_KEY_FILE=
# Local development only — points to fake-gcs-server in docker-compose.
# Leave empty in production.
GCS_EMULATOR_HOST=http://localhost:4443

# ── AI APIs ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Auth (NextAuth.js) ────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Backend Server ─────────────────────────────────────────────────────────────
SERVER_URL=http://localhost:4000
SERVER_PORT=4000
WS_PORT=4000

# ── Next.js Public Env (exposed to browser) ───────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
