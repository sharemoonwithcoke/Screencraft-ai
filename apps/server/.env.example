GEMINI_API_KEY=your_gemini_api_key_here

# Local PostgreSQL (docker-compose)
DATABASE_URL=postgresql://postgres:password@localhost:5432/screencraft

# Local GCS emulator (docker-compose fake-gcs-server)
GCS_PROJECT_ID=local
GCS_BUCKET=screencraft-local
GCS_EMULATOR_HOST=http://localhost:4443

PORT=4000
NODE_ENV=development
